generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String   @default("")
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model SystemProvider {
  id              String   @id @default(uuid())
  name            String   @unique
  icon            String   @default("")
  type            String   @default("official")
  website         String   @default("")
  openaiApiBase   String?  @map("openai_api_base")
  anthropicApiBase String? @map("anthropic_api_base")
  googleApiBase   String?  @map("google_api_base")
  sort            Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("system_providers")
}

model UserProvider {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  name     String
  type     String   @default("custom")
  apiBase  String   @map("api_base") @default("")
  models   String   @default("[]")
  settings String   @default("{}")
  isActive Int      @default(0) @map("is_active")
  sort     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_providers")
}

model UsageRecord {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  providerId       String   @map("provider_id")
  providerName     String   @default("") @map("provider_name")
  modelId          String   @map("model_id")
  timestamp        DateTime @default(now())
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  cacheHitTokens   Int      @default(0) @map("cache_hit_tokens")
  cost             Float    @default(0)
  cliTool          String   @map("cli_tool")
  sessionId        String?  @map("session_id")

  @@index([userId, timestamp])
  @@map("usage_records")
}

model Session {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  cliTool       String   @map("cli_tool")
  providerId    String   @map("provider_id")
  providerName  String   @default("") @map("provider_name")
  modelId       String   @default("") @map("model_id")
  summary       String   @default("")
  messageCount  Int      @default(0) @map("message_count")
  totalTokens   Int      @default(0) @map("total_tokens")
  totalCost     Float    @default(0) @map("total_cost")
  startedAt     DateTime @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, startedAt])
  @@map("sessions")
}

model SessionMessage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  sessionId String   @map("session_id")
  role      String
  content   String
  tokens    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, sessionId])
  @@map("session_messages")
}

model SpeedTest {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  providerId String   @map("provider_id")
  latencyMs  Float    @default(0) @map("latency_ms")
  success    Int      @default(1)
  testedAt   DateTime @default(now()) @map("tested_at")

  @@index([userId, testedAt])
  @@map("speed_tests")
}

model BudgetAlert {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  month         String
  limitAmount   Float    @default(0) @map("limit_amount")
  totalCost     Float    @default(0) @map("total_cost")
  thresholdPct  Int      @default(80) @map("threshold_pct")
  usagePct      Float    @default(0) @map("usage_pct")
  notified      Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, month])
  @@map("budget_alerts")
}

model CompareTest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  prompt    String
  models    String
  responses String   @default("[]")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("compare_tests")
}

model SyncLog {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tableName String    @map("table_name")
  recordId  String    @map("record_id")
  action    String
  syncedAt  DateTime  @default(now()) @map("synced_at")

  @@map("sync_log")
}

model Recommendation {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  taskType         String   @map("task_type")
  recommendedModel String   @map("recommended_model")
  reason           String   @default("")
  usageCount       Int      @default(0) @map("usage_count")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@map("recommendations")
}

model Ad {
  id          String   @id @default(uuid())
  type        String
  title       String   @default("")
  htmlContent String   @default("") @map("html_content")
  textContent String   @default("") @map("text_content")
  linkUrl     String   @default("") @map("link_url")
  width       Int      @default(0)
  height      Int      @default(0)
  enabled     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ads")
}

model DeviceStat {
  id         String   @id @default(uuid())
  deviceId   String   @unique @map("device_id")
  usageCount Int      @default(1) @map("usage_count")
  firstSeen  DateTime @default(now()) @map("first_seen")
  lastSeen   DateTime @default(now()) @map("last_seen")

  @@map("device_stats")
}

model UsageLog {
  id        String   @id @default(uuid())
  deviceId  String   @map("device_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("usage_logs")
}

model AppSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("app_settings")
}
