{
  "name": "@ccmodels/desktop",
  "productName": "CC Models",
  "version": "0.1.0",
  "description": "CC Models - AI model proxy gateway and management tool",
  "homepage": "https://github.com/sohu0025/ccmodels",
  "author": {
    "name": "CC Models",
    "email": "sohu0025@users.noreply.github.com"
  },
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ccmodels/shared": "workspace:*",
    "@lobehub/icons": "^5.8.0",
    "@sentry/electron": "^7.13.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "3",
    "electron-updater": "^6.3.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "daisyui": "^5.5.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  }
}
